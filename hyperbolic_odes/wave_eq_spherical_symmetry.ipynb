   ],
   "source": [
    "plt.plot(r, psi0, label=r'$\\rm \\psi(t=0, r)$')\n",
    "plt.plot(r[1:], psi0[1:]/r[1:], label = r'$\\rm\\phi(t=0, r)$')\n",
    "\n",
    "plt.xlabel('r')\n",
    "plt.ylabel(r'$\\rm\\psi(t=0, r),\\,\\phi(t=0, r)$')\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "4895cd59",
   "metadata": {},
   "outputs": [],
   "source": [
    "history = []\n",
    "u = [psi0, Pi0]\n",
    "for step in range(steps):\n",
    "    u = runge_kutta(u, dt, dr)\n",
    "    if step % idx_appended == 0:\n",
    "        history.append(u[0].copy())"
   ]
  },
  {
